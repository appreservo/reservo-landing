rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Profili utente (gestori, clienti, admin)
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if false;
    }

    // Directory attività (elenco pubblico sul sito)
    match /businesses/{uid} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    // Dati privati dell'attività (impostazioni gestionale)
    match /businessData/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    // Dati pubblici dell'attività (menu, sito pubblico)
    match /businessPublic/{uid} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    // Prenotazioni (creabili anche da utenti anonimi dal sito pubblico)
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn() &&
        (resource.data.businessUid == request.auth.uid ||
         resource.data.customerUid == request.auth.uid ||
         isAdmin());
    }

    // Recensioni
    match /reviews/{reviewId} {
      allow create: if isSignedIn();
      allow read: if true;
      allow update, delete: if isSignedIn() &&
        (resource.data.businessUid == request.auth.uid || isAdmin());
    }

    // Comunicazioni broadcast (elaborate da una Cloud Function)
    match /broadcasts/{broadcastId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() &&
        (resource.data.businessUid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }
  }
}
