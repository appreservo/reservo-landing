rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow delete: if request.auth != null && isAdmin();
    }

    match /businesses/{uid} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    match /businessData/{uid} {
      allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    match /businessPublic/{uid} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update: if request.auth != null &&
        (resource.data.businessUid == request.auth.uid ||
         resource.data.customerUid == request.auth.uid ||
         isAdmin());
      allow delete: if request.auth != null &&
        (resource.data.businessUid == request.auth.uid || isAdmin());
    }

    match /reviews/{reviewId} {
      allow create: if request.auth != null;
      allow read: if true;
      allow update, delete: if request.auth != null &&
        (resource.data.businessUid == request.auth.uid || isAdmin());
    }

    match /feedback/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
